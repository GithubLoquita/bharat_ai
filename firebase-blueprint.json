{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user account information and preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["free", "pro", "business"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Chat": {
      "title": "Chat Session",
      "description": "Represents a conversational session with an AI model.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "model": { "type": "string" },
        "mode": { "type": "string", "enum": ["chat", "coding", "reasoning", "search"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "title"]
    },
    "Message": {
      "title": "Chat Message",
      "description": "A single exchange in a chat session.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "chatId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "model", "system"] },
        "content": { "type": "string" },
        "multimodalData": { "type": "array", "items": { "type": "object" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "chatId", "role", "content"]
    },
    "GeneratedImage": {
      "title": "Generated Image",
      "description": "Metadata for images created via AI.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "prompt": { "type": "string" },
        "url": { "type": "string" },
        "type": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "prompt", "url"]
    },
    "PromptTemplate": {
      "title": "AI Studio Prompt",
      "description": "Saved prompt templates for the developer playground.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "systemPrompt": { "type": "string" },
        "userPrompt": { "type": "string" },
        "config": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "name"]
    },
    "TestConnection": {
      "title": "Connection Test",
      "description": "Minimal heart-beat document for connectivity checks.",
      "type": "object",
      "properties": {
        "status": { "type": "string" }
      }
    },
    "UserSettings": {
      "title": "User Infrastructure Settings",
      "description": "Secure storage for encrypted API keys and AI preferences.",
      "type": "object",
      "properties": {
        "keys": { "type": "object" },
        "preferences": { "type": "object" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Job": {
      "title": "Job Listing",
      "description": "Information about an open position.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "department": { "type": "string" },
        "location": { "type": "string" },
        "type": { "type": "string", "enum": ["Remote", "Onsite", "Hybrid"] },
        "description": { "type": "string" },
        "requirements": { "type": "array", "items": { "type": "string" } },
        "isInternship": { "type": "boolean" },
        "active": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "department", "location", "type"]
    },
    "Application": {
      "title": "Job Application",
      "description": "Submission from a candidate.",
      "type": "object",
      "properties": {
        "jobId": { "type": "string" },
        "jobTitle": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "resumeUrl": { "type": "string" },
        "portfolioUrl": { "type": "string" },
        "note": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "reviewing", "interviewing", "rejected", "hired"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["jobId", "name", "email"]
    },
    "Customer": {
      "title": "Customer / Lead",
      "description": "A business contact in the CRM.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "company": { "type": "string" },
        "status": { "type": "string", "enum": ["Lead", "Client", "Lost"] },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "Professional billing document.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "invoiceNumber": { "type": "string" },
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["Draft", "Sent", "Paid"] },
        "dueDate": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "invoiceNumber", "total"]
    },
    "Deal": {
        "title": "Sales Deal",
        "description": "Revenue opportunity in the pipeline.",
        "type": "object",
        "properties": {
            "userId": { "type": "string" },
            "title": { "type": "string" },
            "value": { "type": "number" },
            "customerId": { "type": "string" },
            "status": { "type": "string", "enum": ["New", "Negotiation", "Won", "Lost"] },
            "createdAt": { "type": "string", "format": "date-time" }
        }
    }
  },
  "firestore": {
    "test-connection/{docId}": {
      "schema": "TestConnection",
      "description": "Publicly readable collection for application health checks."
    },
    "users/{userId}": {
      "schema": "User",
      "description": "Protected user profiles."
    },
    "chats/{chatId}": {
      "schema": "Chat",
      "description": "User chat sessions."
    },
    "chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a chat."
    },
    "images/{imageId}": {
      "schema": "GeneratedImage",
      "description": "Metadata for user-generated images."
    },
    "studio/{promptId}": {
      "schema": "PromptTemplate",
      "description": "User prompt templates."
    },
    "users/{userId}/config/{configId}": {
      "schema": "UserSettings",
      "description": "Encrypted infrastructure configuration."
    },
    "jobs/{jobId}": {
      "schema": "Job",
      "description": "Public job listings."
    },
    "applications/{applicationId}": {
      "schema": "Application",
      "description": "Submitted candidate applications."
    },
    "customers/{customerId}": {
      "schema": "Customer",
      "description": "CRM customer records."
    },
    "invoices/{invoiceId}": {
      "schema": "Invoice",
      "description": "Business invoices."
    },
    "deals/{dealId}": {
      "schema": "Deal",
      "description": "Sales pipeline deals."
    }
  }
}
